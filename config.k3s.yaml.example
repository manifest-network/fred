# K3s Backend Configuration Example
#
# Copy this file to config.k3s.yaml and customize for your environment.
#
# Quick start:
#   1. Generate a callback secret:  openssl rand -hex 32
#   2. Fill in `callback_secret` and `host_address` below.
#   3. Confirm `kubeconfig_path` points to your kubeconfig. The K3s
#      installer's default is /etc/rancher/k3s/k3s.yaml.
#   4. Add at least one `sku_mapping` entry so the chain SKU UUIDs you
#      care about route to a local profile.

# Log verbosity. Valid values: debug, info, warn, error. Default: info.
# log_level: "info"

# Backend name (used in Fred configuration to route by SKU).
name: k3s

# HTTP server listen address. Use :9002 to avoid colliding with the
# docker-backend default of :9001 if both run on the same host.
listen_addr: ":9002"

# =============================================================================
# KUBECONFIG
# =============================================================================
# Path to the kubeconfig file used by k8s.io/client-go to reach the K3s
# API server. The K3s installer writes its default kubeconfig to
# /etc/rancher/k3s/k3s.yaml. Use an absolute path here — Go's stdlib does
# not expand "~", and neither does the backend's resolver. If you copied
# the kubeconfig elsewhere (for example to ~/.kube/k3s.yaml), edit this
# value to point at the absolute path of that copy.
#
# When this field is empty, the backend resolves the client config in
# this order: in-cluster config (when running inside a Pod) → $KUBECONFIG
# env var → ~/.kube/config (the last is resolved by client-go itself,
# not by this YAML).

kubeconfig_path: "/etc/rancher/k3s/k3s.yaml"

# =============================================================================
# RESOURCE POOL
# =============================================================================
# Total resources available for provisioning workloads. The ENG-133 scaffold
# does not allocate against these (the provisioner is a stub), but the values
# are validated and reserved by the resource pool so later children plug in
# without changing the schema.

total_cpu_cores: 8.0
total_memory_mb: 16384
total_disk_mb: 102400

# =============================================================================
# SKU MAPPING (REQUIRED)
# =============================================================================
# Maps on-chain SKU UUIDs to local profile names. When a tenant creates a
# lease, the chain assigns a SKU UUID. This mapping tells the backend which
# resource profile to provision.
#
# To get your SKU UUIDs:
#   manifestd query sku skus-by-provider <your-provider-uuid>
#
# Then map each UUID to a profile below:
sku_mapping:
  "019c1ee7-1aaf-7000-802c-ad775c72cc27": "k3s-micro"
  "019c1ee7-816c-7001-8c26-a61d57e7403e": "k3s-small"
  "019c1ee8-3ef5-7002-beb3-07a3d4b8ce95": "k3s-medium"
  "019c1ee8-9d9c-7003-8d01-4188dfe9e204": "k3s-large"
  # Add your SKU UUIDs here...

# SKU profiles define resource limits for each tier.
# Profile names are referenced by sku_mapping above.
sku_profiles:
  k3s-micro:
    cpu_cores: 0.25
    memory_mb: 256
    disk_mb: 512
  k3s-small:
    cpu_cores: 0.5
    memory_mb: 512
    disk_mb: 1024
  k3s-medium:
    cpu_cores: 1.0
    memory_mb: 1024
    disk_mb: 2048
  k3s-large:
    cpu_cores: 2.0
    memory_mb: 2048
    disk_mb: 4096

# =============================================================================
# TENANT QUOTAS (optional)
# =============================================================================
# Per-tenant resource limits. Prevents any single tenant from consuming the
# entire resource pool. Leave commented out to allow full pool usage.
#
# tenant_quota:
#   max_cpu_cores: 4.0
#   max_memory_mb: 8192
#   max_disk_mb: 51200

# =============================================================================
# ALLOWED REGISTRIES
# =============================================================================
# Security: Only images from these registries can be pulled.

allowed_registries:
  - "docker.io"
  - "ghcr.io"
  # Add more registries as needed:
  # - "gcr.io"
  # - "registry.example.com"

# =============================================================================
# CALLBACK CONFIGURATION
# =============================================================================
# Settings for callbacks to Fred reporting provisioning results.

# HMAC secret for signing callbacks to Fred (minimum 32 characters).
# REQUIRED — k3s-backend refuses to start with an empty value.
# Generate with: openssl rand -hex 32
# Must match callback_secret configured on the Fred side.
callback_secret: ""

# Skip TLS certificate verification for callbacks (development only!).
# WARNING: Never enable in production — vulnerable to MITM attacks.
# callback_insecure_skip_verify: false

# Path to bbolt database for persisting pending callbacks.
# Callbacks are stored before delivery to survive restarts. Default: callbacks.db.
callback_db_path: "callbacks.db"

# Maximum age of persisted callback entries. Entries older than this are
# removed during startup replay. Default: 24h.
callback_max_age: 24h

# =============================================================================
# DIAGNOSTICS
# =============================================================================
# Failure diagnostics (error messages and pod/container output) are persisted
# to a bbolt database so they survive deprovision and backend restarts. The
# GET /provisions/{lease_uuid} and GET /logs/{lease_uuid} endpoints fall back
# to this store when the provision is no longer in memory.

# Path to bbolt database for persisting failure diagnostics. Default: diagnostics.db.
diagnostics_db_path: "diagnostics.db"

# Maximum age of persisted diagnostic entries. Default: 7 days (168h).
diagnostics_max_age: 168h

# =============================================================================
# RELEASE HISTORY
# =============================================================================
# Tracks deployment releases (provisions, updates) per lease. The
# GET /releases/{lease_uuid} endpoint returns this history. Releases are
# persisted to a bbolt database so they survive backend restarts.

# Path to bbolt database for persisting release history. Default: releases.db.
releases_db_path: "releases.db"

# Maximum age of persisted release entries. Default: 90 days (2160h).
releases_max_age: 2160h

# =============================================================================
# HOST CONFIGURATION
# =============================================================================

# External host address returned to tenants in connection info responses.
# Must be a valid hostname or IP address (not a URL).
# REQUIRED — k3s-backend refuses to start with an empty value.
host_address: ""

# =============================================================================
# RECONCILIATION
# =============================================================================

# How often to reconcile in-memory state with the cluster. In the ENG-133
# scaffold no reconcile loop is started; later children consume this value.
# Default: 5m.
reconcile_interval: 5m

# =============================================================================
# INGRESS (placeholder — not supported in ENG-133 scaffold)
# =============================================================================
# Reserved for the K3s ingress story (Ingress / Gateway API mapping). The
# k3s-backend scaffold rejects `enabled: true` at startup. The field shape
# is fixed here so the YAML doesn't have to change schema when a later
# child wires up real ingress support.
#
# ingress:
#   enabled: false
#   class_name: "traefik"
